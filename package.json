    "commands": [
      {
        "command": "codexCat.installHooks",
        "title": "Codex Cat: Install Hooks"
      },
      {
        "command": "codexCat.reinstallHooks",
        "title": "Codex Cat: Reinstall Hooks"
      },
      {
        "command": "codexCat.uninstallHooks",
        "title": "Codex Cat: Uninstall Hooks"
      },
      {
        "command": "codexCat.testStart",
        "title": "Codex Cat: Test Start"
      },
      {
        "command": "codexCat.testStop",
        "title": "Codex Cat: Test Stop"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:production",
    "vscode:uninstall": "node ./dist/uninstall.js",
    "generate:icons": "node tools/generate-cat-animation.cjs",
    "check-types": "tsc --noEmit -p ./",
    "bundle": "node tools/build-extension.cjs",
    "compile": "npm run generate:icons && npm run check-types && npm run bundle",
    "build:production": "npm run generate:icons && npm run check-types && npm run bundle -- --production",
    "watch": "npm run generate:icons && node tools/build-extension.cjs --watch",
    "pretest": "npm run compile && npm run lint && tsc -p ./",
    "lint": "eslint src",
    "test": "vscode-test",
    "package:check": "npm run build:production && npm run lint && node tools/verify-package-contents.cjs",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@neplex/vectorizer": "^0.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "fantasticon": "^4.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
