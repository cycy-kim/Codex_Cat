{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022"],
    "module": "Node16",
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "mocha"]
  },
  "include": ["src/**/*.ts"]
}
